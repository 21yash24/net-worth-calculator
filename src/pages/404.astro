---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 Page Not Found | Net Worth Calculator">
	<main class="max-w-md mx-auto px-6 py-24 text-center">
		<div class="w-20 h-20 bg-emerald-500/10 border border-emerald-500/30 rounded-full flex items-center justify-center mx-auto mb-6 text-emerald-600 dark:text-emerald-400">
			<span class="text-3xl font-black">$</span>
		</div>
		<h1 class="text-4xl font-extrabold text-slate-900 dark:text-white mb-2 tracking-tight">404 - Page Not Found</h1>
		<p class="text-slate-700 dark:text-slate-400 mb-8">The page you're looking for doesn't exist or has moved.</p>
		<a href="/" class="inline-block px-6 py-3.5 rounded-xl bg-emerald-700 hover:bg-emerald-600 text-white font-bold transition-all shadow-md">
			Return to Calculator
		</a>
	</main>
</Layout>
