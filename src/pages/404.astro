---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 Page Not Found | Net Worth Calculator">
	<main class="max-w-md mx-auto px-4 py-24 text-center">
		<div class="w-20 h-20 bg-sky-500/10 border border-sky-500/30 rounded-full flex items-center justify-center mx-auto mb-6">
			<span class="text-sky-400 text-3xl font-black">$</span>
		</div>
		<h1 class="text-4xl font-bold text-white mb-2">404 - Page Not Found</h1>
		<p class="text-slate-400 mb-8">The page you're looking for doesn't exist or has moved.</p>
		<a href="/" class="inline-block px-6 py-3 rounded-xl bg-sky-500 hover:bg-sky-400 text-white font-semibold transition-all">
			Return to Calculator
		</a>
	</main>
</Layout>
