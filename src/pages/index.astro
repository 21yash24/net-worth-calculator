---
import Layout from '../layouts/Layout.astro';
import fedData from '../data/fedData.json';

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Net Worth Calculator by Age",
  "url": "https://networthbyage.com",
  "description": "Calculate your exact net worth percentile by age benchmarked against official US Federal Reserve Survey of Consumer Finances (SCF) data.",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "All",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the average net worth by age in the US?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "According to the US Federal Reserve Survey of Consumer Finances (SCF), median net worth varies significantly by age: Under 35 is ~$39,000; 35-44 is ~$135,600; 45-54 is ~$247,200; 55-64 is ~$364,500; and 65-74 is ~$409,900."
      }
    },
    {
      "@type": "Question",
      "name": "Should I include primary residence home equity in my net worth?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Total net worth includes home equity (home value minus mortgage balance). However, liquid net worth excludes primary residence home equity to focus on cash, investments, and retirement accounts. Our calculator includes a toggle so you can test both."
      }
    },
    {
      "@type": "Question",
      "name": "What net worth makes you top 10% by age 30?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For Americans under age 35, a net worth of approximately $340,000 puts you in the top 10th percentile according to Federal Reserve data."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between average and median net worth?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Average net worth is calculated by adding all net worths and dividing by the total population, which is heavily distorted upward by billionaires. Median net worth represents the exact middle individual (50th percentile) and is a much more realistic benchmark."
      }
    }
  ]
};
---

<Layout title="Net Worth Calculator by Age | Official Federal Reserve Benchmark" description="Calculate your exact net worth percentile by age using official US Federal Reserve data. Compare your wealth, liquid assets, and savings benchmarks. 100% free & private.">
	
	<!-- JSON-LD Schema Scripts -->
	<script type="application/ld+json" set:html={JSON.stringify(webAppSchema)} />
	<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

	<main class="max-w-4xl mx-auto px-6 py-10 md:py-16">
		<header class="text-center mb-12 space-y-4">
			<div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full bg-slate-200/80 dark:bg-slate-900/80 border border-slate-300 dark:border-slate-800 text-slate-800 dark:text-slate-300 text-xs font-semibold">
				<span class="w-1.5 h-1.5 rounded-full bg-emerald-500" aria-hidden="true"></span>
				Official US Federal Reserve SCF Dataset
			</div>
			
			<h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-slate-900 dark:text-white tracking-tight">
				Net Worth Calculator <span class="text-slate-600 dark:text-slate-400 font-normal">by Age</span>
			</h1>
			<p class="text-slate-850 dark:text-slate-400 text-base md:text-lg max-w-xl mx-auto font-normal leading-relaxed">
				Benchmark your personal wealth percentile against official US population data.
			</p>
		</header>

		<!-- Main Interactive Calculator Panel -->
		<div class="p-6 md:p-10 rounded-3xl border border-slate-200 dark:border-slate-800/80 shadow-xl dark:shadow-2xl relative overflow-hidden backdrop-blur-xl bg-white/95 dark:bg-slate-900/40 transition-colors duration-300">
			
			<div class="space-y-8">
				<!-- Top Controls Bar: Currency Selector & Options -->
				<div class="flex items-center justify-between flex-wrap gap-4 pb-4 border-b border-slate-200 dark:border-slate-800/80">
					<div class="flex items-center gap-2">
						<label for="currency-select" class="text-xs font-bold uppercase tracking-wider text-slate-750 dark:text-slate-300">Currency:</label>
						<select id="currency-select" class="bg-slate-100 dark:bg-slate-950 border border-slate-300 dark:border-slate-800 text-slate-900 dark:text-white text-xs font-bold rounded-lg px-3 py-1.5 outline-none focus:ring-1 focus:ring-emerald-500 cursor-pointer">
							<option value="USD" data-symbol="$">USD ($)</option>
							<option value="GBP" data-symbol="£">GBP (£)</option>
							<option value="EUR" data-symbol="€">EUR (€)</option>
							<option value="CAD" data-symbol="$">CAD ($)</option>
							<option value="AUD" data-symbol="$">AUD ($)</option>
							<option value="INR" data-symbol="₹">INR (₹)</option>
						</select>
					</div>

					<!-- Option Toggle: Home Equity -->
					<div class="flex items-center gap-3">
						<span class="text-xs font-bold text-slate-700 dark:text-slate-300">Include Home Equity</span>
						<label class="relative inline-flex items-center cursor-pointer">
							<input type="checkbox" id="home-equity-toggle" checked class="sr-only peer" aria-label="Toggle Include Home Equity in Net Worth">
							<div class="w-9 h-5 bg-slate-300 dark:bg-slate-800 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-slate-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-emerald-500"></div>
						</label>
					</div>
				</div>

				<!-- Input 1: Age Slider -->
				<div class="space-y-3">
					<div class="flex justify-between items-center">
						<label for="age-input" class="text-base font-bold text-slate-800 dark:text-slate-200">
							Your Age
						</label>
						<span id="age-display" class="text-xl font-bold text-slate-900 dark:text-white bg-slate-100 dark:bg-slate-950 px-4 py-1.5 rounded-xl border border-slate-200 dark:border-slate-800">
							32 years
						</span>
					</div>
					<input type="range" id="age-input" min="18" max="80" value="32" class="w-full h-2 bg-slate-200 dark:bg-slate-950 rounded-lg appearance-none cursor-pointer accent-emerald-500 border border-slate-300 dark:border-slate-800" aria-label="Enter your age range" title="Age range slider">
					<div class="flex justify-between text-xs text-slate-750 dark:text-slate-400 font-bold px-1">
						<span>18</span>
						<span>30</span>
						<span>40</span>
						<span>50</span>
						<span>60</span>
						<span>70</span>
						<span>80</span>
					</div>
				</div>

				<!-- Input 2: Net Worth Input & Slider -->
				<div class="space-y-3">
					<div class="flex justify-between items-center flex-wrap gap-3">
						<label for="nw-number-input" class="text-base font-bold text-slate-800 dark:text-slate-200">
							Total Net Worth (<span class="curr-symbol">$</span>)
						</label>
						<div class="relative">
							<span class="curr-symbol absolute left-3.5 top-1/2 -translate-y-1/2 text-slate-500 font-medium">$</span>
							<input type="number" id="nw-number-input" value="120000" step="5000" class="bg-slate-100 dark:bg-slate-950 border border-slate-300 dark:border-slate-800 text-emerald-600 dark:text-emerald-400 text-lg font-bold rounded-xl pl-8 pr-4 py-2.5 w-48 focus:ring-1 focus:ring-emerald-500 outline-none" aria-label="Enter net worth amount">
						</div>
					</div>
					<input type="range" id="nw-slider-input" min="-20000" max="2000000" step="5000" value="120000" class="w-full h-2 bg-slate-200 dark:bg-slate-950 rounded-lg appearance-none cursor-pointer accent-emerald-500 border border-slate-300 dark:border-slate-800" aria-label="Slider adjust net worth amount" title="Net worth range slider">
					<div class="flex justify-between text-xs text-slate-750 dark:text-slate-400 font-bold px-1">
						<span>-<span class="curr-symbol">$</span>20k</span>
						<span><span class="curr-symbol">$</span>100k</span>
						<span><span class="curr-symbol">$</span>500k</span>
						<span><span class="curr-symbol">$</span>1M</span>
						<span><span class="curr-symbol">$</span>2M+</span>
					</div>
				</div>
			</div>

			<!-- Dynamic Percentile Results Display -->
			<div class="mt-10 pt-8 border-t border-slate-200 dark:border-slate-800/80 space-y-6">
				<div class="text-center space-y-2">
					<span class="text-xs font-bold uppercase tracking-wider text-slate-750 dark:text-slate-400">Wealth Percentile Benchmark</span>
					<div id="percentile-badge" class="text-4xl md:text-5xl font-extrabold text-slate-900 dark:text-white tracking-tight">
						Top 28% Percentile
					</div>
					<p id="comparison-summary" class="text-slate-800 dark:text-slate-300 text-base max-w-lg mx-auto font-normal">
						At age <span class="text-slate-900 dark:text-white font-semibold">32</span> with <span class="text-emerald-650 dark:text-emerald-400 font-semibold"><span class="curr-symbol">$</span>120,000</span> net worth, you have more wealth than <span class="text-emerald-650 dark:text-emerald-400 font-semibold">72%</span> of Americans in your age group.
					</p>
				</div>

				<!-- Interactive Visual Wealth Bell Curve SVG -->
				<div class="p-4 rounded-2xl bg-slate-100/70 dark:bg-slate-950/60 border border-slate-200 dark:border-slate-800/80 space-y-2">
					<div class="flex justify-between text-xs font-bold text-slate-750 dark:text-slate-400">
						<span>US Population Wealth Distribution Curve</span>
						<span id="curve-marker-text" class="text-emerald-600 dark:text-emerald-400 font-bold">You are at 72%</span>
					</div>
					<div class="relative w-full h-24">
						<svg class="w-full h-full overflow-visible" viewBox="0 0 400 80" preserveAspectRatio="none" role="img" aria-label="Interactive Wealth Distribution Curve Chart">
							<!-- Bell Curve Path -->
							<path d="M 0,75 Q 100,75 160,55 T 200,10 T 240,55 Q 300,75 400,75" fill="none" stroke="currentColor" class="text-slate-400 dark:text-slate-800" stroke-width="3"/>
							<!-- Shaded Area Under Curve -->
							<path id="curve-fill-path" d="M 0,75 Q 100,75 160,55 T 200,10 T 240,55 Q 300,75 400,75 L 400,80 L 0,80 Z" class="fill-emerald-500/20"/>
							<!-- Active Dot Marker -->
							<circle id="curve-dot" cx="288" cy="62" r="7" class="fill-emerald-500 stroke-white dark:stroke-slate-950" stroke-width="2.5"/>
						</svg>
					</div>
				</div>

				<!-- Benchmarks Matrix Grid -->
				<div class="grid grid-cols-2 sm:grid-cols-4 gap-3 pt-2">
					<div class="p-4 rounded-xl bg-slate-100/80 dark:bg-slate-950/60 border border-slate-200 dark:border-slate-800/80 text-center">
						<span class="text-xs text-slate-750 dark:text-slate-400 block mb-1 font-bold">Median (50th)</span>
						<span id="bm-p50" class="text-base font-bold text-slate-900 dark:text-white">$39,000</span>
					</div>
					<div class="p-4 rounded-xl bg-slate-100/80 dark:bg-slate-950/60 border border-slate-200 dark:border-slate-800/80 text-center">
						<span class="text-xs text-slate-750 dark:text-slate-400 block mb-1 font-bold">Top 25% (75th)</span>
						<span id="bm-p75" class="text-base font-bold text-slate-750 dark:text-slate-200">$145,000</span>
					</div>
					<div class="p-4 rounded-xl bg-slate-100/80 dark:bg-slate-950/60 border border-slate-200 dark:border-slate-800/80 text-center">
						<span class="text-xs text-slate-750 dark:text-slate-400 block mb-1 font-bold">Top 10% (90th)</span>
						<span id="bm-p90" class="text-base font-bold text-emerald-650 dark:text-emerald-400">$340,000</span>
					</div>
					<div class="p-4 rounded-xl bg-slate-100/80 dark:bg-slate-950/60 border border-slate-200 dark:border-slate-800/80 text-center">
						<span class="text-xs text-slate-750 dark:text-slate-400 block mb-1 font-bold">Top 1% (99th)</span>
						<span id="bm-p99" class="text-base font-bold text-amber-650 dark:text-amber-400">$1,400,000</span>
					</div>
				</div>

				<!-- Age-Based Ideal Asset Allocation Benchmark Card -->
				<div class="p-5 rounded-2xl bg-slate-100/90 dark:bg-slate-950 border border-slate-200 dark:border-slate-800/80 space-y-3">
					<div class="flex items-center justify-between">
						<span class="text-xs font-bold text-slate-900 dark:text-white uppercase tracking-wider">Recommended Asset Allocation for Age <span id="asset-age-label">32</span></span>
						<span class="text-xs text-slate-750 dark:text-slate-400 font-bold">Benchmark Model</span>
					</div>
					<div id="asset-breakdown-grid" class="grid grid-cols-2 sm:grid-cols-4 gap-2 text-xs">
						<!-- Populated via JS -->
					</div>
				</div>

				<!-- Actionable Target Box & Share Button -->
				<div class="p-4 rounded-xl bg-emerald-50 dark:bg-slate-950 border border-emerald-200 dark:border-slate-800 flex flex-col sm:flex-row items-center justify-between gap-4 text-center sm:text-left">
					<div>
						<span class="text-xs font-bold text-emerald-850 dark:text-emerald-450 uppercase tracking-wider block mb-1">Wealth Goal Milestone</span>
						<p id="milestone-text" class="text-sm text-slate-850 dark:text-slate-300">
							To reach the <strong class="text-emerald-650 dark:text-emerald-450">Top 10%</strong> for your age group, you need an additional <strong class="text-slate-900 dark:text-white">$220,000</strong>.
						</p>
					</div>

					<button id="copy-summary-btn" class="shrink-0 px-4 py-2.5 rounded-xl bg-emerald-600 hover:bg-emerald-500 text-white font-bold text-xs flex items-center gap-2 transition-all shadow-sm">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
						</svg>
						<span>Copy Summary</span>
					</button>
				</div>
			</div>
		</div>

		<!-- 600-Word On-Page SEO Content Section -->
		<article class="mt-20 max-w-3xl mx-auto space-y-8 text-slate-750 dark:text-slate-400 leading-relaxed font-normal">
			<section>
				<h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-3">Understanding US Net Worth Benchmarks</h2>
				<p class="mb-4">
					Net worth represents the total value of all your assets (savings, investments, retirement accounts, home equity) minus all liabilities (mortgages, student loans, consumer debt).
				</p>
				<p>
					According to official data from the <strong>Federal Reserve Survey of Consumer Finances (SCF)</strong>, household wealth expands significantly as Americans advance through their peak earning years and compound investment returns.
				</p>
			</section>

			<section>
				<h2 class="text-xl font-bold text-slate-900 dark:text-white mb-3">Average vs. Median Net Worth</h2>
				<p class="mb-4">
					Financial media frequently reports "Average Net Worth", which is mathematically distorted by ultra-wealthy billionaires. <strong>Median Net Worth (50th Percentile)</strong> represents the true midpoint of the population—50% of people have more, and 50% have less—making it the most accurate baseline for personal comparison.
				</p>
			</section>
		</article>

		<!-- SEO-Optimized Accordion FAQ Section -->
		<section class="mt-16 max-w-3xl mx-auto">
			<h2 class="text-2xl font-bold text-center text-slate-900 dark:text-white mb-6">Frequently Asked Questions</h2>
			
			<div class="space-y-3">
				<details class="p-5 rounded-xl border border-slate-200 dark:border-slate-800/80 bg-white dark:bg-slate-900/40 cursor-pointer group shadow-sm">
					<summary class="text-base font-semibold text-slate-900 dark:text-white flex justify-between items-center list-none">
						<span>What is the average net worth by age in the US?</span>
						<span class="text-slate-600 dark:text-slate-400 group-open:rotate-180 transition-transform" aria-hidden="true">▼</span>
					</summary>
					<p class="text-slate-750 dark:text-slate-400 mt-3 text-sm leading-relaxed">
						According to the Federal Reserve, median net worth by age is: Under 35 (~$39,000); 35-44 (~$135,600); 45-54 (~$247,200); 55-64 (~$364,500); 65-74 (~$409,900).
					</p>
				</details>

				<details class="p-5 rounded-xl border border-slate-200 dark:border-slate-800/80 bg-white dark:bg-slate-900/40 cursor-pointer group shadow-sm">
					<summary class="text-base font-semibold text-slate-900 dark:text-white flex justify-between items-center list-none">
						<span>Should I include primary residence home equity in my net worth?</span>
						<span class="text-slate-650 dark:text-slate-400 group-open:rotate-180 transition-transform" aria-hidden="true">▼</span>
					</summary>
					<p class="text-slate-705 dark:text-slate-400 mt-3 text-sm leading-relaxed">
						Total net worth includes home equity (home value minus mortgage). Liquid net worth excludes primary residence home equity to focus strictly on cash and liquid investments. Our tool allows you to toggle both.
					</p>
				</details>

				<details class="p-5 rounded-xl border border-slate-200 dark:border-slate-800/80 bg-white dark:bg-slate-900/40 cursor-pointer group shadow-sm">
					<summary class="text-base font-semibold text-slate-900 dark:text-white flex justify-between items-center list-none">
						<span>What net worth puts you in the top 10% under age 35?</span>
						<span class="text-slate-650 dark:text-slate-400 group-open:rotate-180 transition-transform" aria-hidden="true">▼</span>
					</summary>
					<p class="text-slate-705 dark:text-slate-400 mt-3 text-sm leading-relaxed">
						For Americans under age 35, a net worth of approximately $340,000 puts you in the 90th percentile (top 10%).
					</p>
				</details>
			</div>
		</section>

		<!-- High-CPM Ad Placeholder -->
		<div class="mt-16 text-center text-xs text-slate-650 dark:text-slate-500 border border-dashed border-slate-300 dark:border-slate-800 bg-slate-100/50 dark:bg-slate-900/20 rounded-xl p-8 max-w-xl mx-auto">
			<span>Ad Space / High-Yield Savings Partner Placeholder</span>
		</div>
	</main>
</Layout>

<script is:inline>
	const scfBrackets = {
		under_35: { p10: -5000, p25: 3200, p50: 39000, p75: 145000, p90: 340000, p95: 580000, p99: 1400000 },
		b35_44:   { p10: -12000, p25: 24000, p50: 135600, p75: 410000, p90: 980000, p95: 1850000, p99: 4500000 },
		b45_54:   { p10: -8000, p25: 48000, p50: 247200, p75: 780000, p90: 1950000, p95: 3800000, p99: 9200000 },
		b55_64:   { p10: -2000, p25: 65000, p50: 364500, p75: 1150000, p90: 2800000, p95: 5400000, p99: 14500000 },
		b65_74:   { p10: 2000, p25: 82000, p50: 409900, p75: 1380000, p90: 3400000, p95: 6800000, p99: 17800000 },
		b75_plus: { p10: 5000, p25: 75000, p50: 335600, p75: 1100000, p90: 2900000, p95: 5900000, p99: 15200000 }
	};

	let currentSymbol = '$';

	document.addEventListener('DOMContentLoaded', () => {
		const ageInput = document.getElementById('age-input');
		const ageDisplay = document.getElementById('age-display');
		const nwNumberInput = document.getElementById('nw-number-input');
		const nwSliderInput = document.getElementById('nw-slider-input');
		const homeEquityToggle = document.getElementById('home-equity-toggle');
		const currencySelect = document.getElementById('currency-select');
		const copySummaryBtn = document.getElementById('copy-summary-btn');

		const percentileBadge = document.getElementById('percentile-badge');
		const comparisonSummary = document.getElementById('comparison-summary');
		const curveDot = document.getElementById('curve-dot');
		const curveMarkerText = document.getElementById('curve-marker-text');
		const milestoneText = document.getElementById('milestone-text');
		const assetAgeLabel = document.getElementById('asset-age-label');
		const assetBreakdownGrid = document.getElementById('asset-breakdown-grid');

		const bmP50 = document.getElementById('bm-p50');
		const bmP75 = document.getElementById('bm-p75');
		const bmP90 = document.getElementById('bm-p90');
		const bmP99 = document.getElementById('bm-p99');

		function getBracket(age) {
			if (age < 35) return scfBrackets.under_35;
			if (age <= 44) return scfBrackets.b35_44;
			if (age <= 54) return scfBrackets.b45_54;
			if (age <= 64) return scfBrackets.b55_64;
			if (age <= 74) return scfBrackets.b65_74;
			return scfBrackets.b75_plus;
		}

		function formatCurrency(val) {
			const absVal = Math.abs(val).toLocaleString();
			return (val < 0 ? '-' : '') + currentSymbol + absVal;
		}

		function calculatePercentile(nw, b) {
			if (nw < b.p10) return 5;
			if (nw < b.p25) return Math.round(10 + (nw - b.p10) / (b.p25 - b.p10) * 15);
			if (nw < b.p50) return Math.round(25 + (nw - b.p25) / (b.p50 - b.p25) * 25);
			if (nw < b.p75) return Math.round(50 + (nw - b.p50) / (b.p75 - b.p50) * 25);
			if (nw < b.p90) return Math.round(75 + (nw - b.p75) / (b.p90 - b.p75) * 15);
			if (nw < b.p95) return Math.round(90 + (nw - b.p90) / (b.p95 - b.p90) * 5);
			if (nw < b.p99) return Math.round(95 + (nw - b.p95) / (b.p99 - b.p95) * 4);
			return 99;
		}

		function updateAssetBreakdown(age) {
			if (!assetAgeLabel || !assetBreakdownGrid) return;
			assetAgeLabel.textContent = age;

			let equities = '70%', realEstate = '15%', cash = '10%', alt = '5%';
			if (age >= 50) {
				equities = '50%'; realEstate = '25%'; cash = '20%'; alt = '5%';
			} else if (age >= 40) {
				equities = '60%'; realEstate = '20%'; cash = '15%'; alt = '5%';
			}

			assetBreakdownGrid.innerHTML = `
				<div class="p-2.5 rounded-lg bg-slate-200/60 dark:bg-slate-900 border border-slate-300 dark:border-slate-800 text-center">
					<span class="text-slate-650 dark:text-slate-400 block text-[10px] font-bold">Equities / Stocks</span>
					<strong class="text-slate-900 dark:text-white text-sm">${equities}</strong>
				</div>
				<div class="p-2.5 rounded-lg bg-slate-200/60 dark:bg-slate-900 border border-slate-300 dark:border-slate-800 text-center">
					<span class="text-slate-650 dark:text-slate-400 block text-[10px] font-bold">Real Estate / Home</span>
					<strong class="text-slate-900 dark:text-white text-sm">${realEstate}</strong>
				</div>
				<div class="p-2.5 rounded-lg bg-slate-200/60 dark:bg-slate-900 border border-slate-300 dark:border-slate-800 text-center">
					<span class="text-slate-650 dark:text-slate-400 block text-[10px] font-bold">Cash / HYSA</span>
					<strong class="text-slate-900 dark:text-white text-sm">${cash}</strong>
				</div>
				<div class="p-2.5 rounded-lg bg-slate-200/60 dark:bg-slate-900 border border-slate-300 dark:border-slate-800 text-center">
					<span class="text-slate-650 dark:text-slate-400 block text-[10px] font-bold">Alternatives</span>
					<strong class="text-slate-900 dark:text-white text-sm">${alt}</strong>
				</div>
			`;
		}

		function updateCalculator() {
			const age = parseInt(ageInput.value);
			let nw = parseFloat(nwNumberInput.value) || 0;
			const includeHomeEquity = homeEquityToggle.checked;

			if (!includeHomeEquity) {
				nw = nw * 0.75;
			}

			ageDisplay.textContent = age + ' years';
			
			const b = getBracket(age);

			bmP50.textContent = formatCurrency(b.p50);
			bmP75.textContent = formatCurrency(b.p75);
			bmP90.textContent = formatCurrency(b.p90);
			bmP99.textContent = formatCurrency(b.p99);

			const p = calculatePercentile(nw, b);
			const topPercent = 100 - p;

			const dotX = Math.min(390, Math.max(10, (p / 100) * 400));
			if (curveDot) curveDot.setAttribute('cx', dotX.toString());
			if (curveMarkerText) curveMarkerText.textContent = `You are at ${p}%`;

			if (p >= 90) {
				percentileBadge.textContent = 'Top ' + (topPercent <= 1 ? '1%' : topPercent + '%') + ' Percentile';
				percentileBadge.className = 'text-4xl md:text-5xl font-extrabold text-amber-500 dark:text-amber-400 tracking-tight';
			} else if (p >= 50) {
				percentileBadge.textContent = 'Top ' + topPercent + '% Percentile';
				percentileBadge.className = 'text-4xl md:text-5xl font-extrabold text-slate-900 dark:text-white tracking-tight';
			} else {
				percentileBadge.textContent = p + 'th Percentile';
				percentileBadge.className = 'text-4xl md:text-5xl font-extrabold text-slate-700 dark:text-slate-300 tracking-tight';
			}

			comparisonSummary.innerHTML = `At age <span class="text-slate-900 dark:text-white font-semibold">${age}</span> with <span class="text-emerald-600 dark:text-emerald-400 font-semibold">${formatCurrency(nw)}</span> net worth, you have more wealth than <span class="text-emerald-600 dark:text-emerald-400 font-semibold">${p}%</span> of Americans in your age group.`;

			if (nw < b.p50) {
				const diff = b.p50 - nw;
				milestoneText.innerHTML = `To reach the <strong class="text-slate-900 dark:text-slate-200 font-bold">50th Percentile (Median)</strong> for your age group, you need an additional <strong class="text-slate-900 dark:text-white">${formatCurrency(diff)}</strong>.`;
			} else if (nw < b.p75) {
				const diff = b.p75 - nw;
				milestoneText.innerHTML = `To reach the <strong class="text-slate-900 dark:text-slate-200 font-bold">Top 25%</strong> for your age group, you need an additional <strong class="text-slate-900 dark:text-white">${formatCurrency(diff)}</strong>.`;
			} else if (nw < b.p90) {
				const diff = b.p90 - nw;
				milestoneText.innerHTML = `To reach the <strong class="text-emerald-650 dark:text-emerald-450 font-bold">Top 10%</strong> for your age group, you need an additional <strong class="text-slate-900 dark:text-white">${formatCurrency(diff)}</strong>.`;
			} else if (nw < b.p99) {
				const diff = b.p99 - nw;
				milestoneText.innerHTML = `To reach the elite <strong class="text-amber-600 dark:text-amber-500 font-bold">Top 1%</strong> for your age group, you need an additional <strong class="text-slate-900 dark:text-white">${formatCurrency(diff)}</strong>.`;
			} else {
				milestoneText.innerHTML = `🏆 <strong class="text-amber-600 dark:text-amber-500 font-bold">Congratulations!</strong> You are in the top 1% of wealth for your age group in the United States.`;
			}

			updateAssetBreakdown(age);
		}

		currencySelect?.addEventListener('change', (e) => {
			const selectedOption = e.target.options[e.target.selectedIndex];
			currentSymbol = selectedOption.getAttribute('data-symbol') || '$';
			
			document.querySelectorAll('.curr-symbol').forEach(el => {
				el.textContent = currentSymbol;
			});
			updateCalculator();
		});

		copySummaryBtn?.addEventListener('click', () => {
			const age = ageInput.value;
			const nw = formatCurrency(parseFloat(nwNumberInput.value) || 0);
			const textToCopy = `🏆 Net Worth Percentile Benchmark: At age ${age} with ${nw} net worth, I am in the ${percentileBadge.textContent} (US Federal Reserve Benchmark). Checked at https://getnetworthcalculator.com`;
			
			navigator.clipboard.writeText(textToCopy);
			alert('Summary copied to clipboard!');
		});

		ageInput.addEventListener('input', updateCalculator);
		
		nwNumberInput.addEventListener('input', (e) => {
			nwSliderInput.value = e.target.value;
			updateCalculator();
		});

		nwSliderInput.addEventListener('input', (e) => {
			nwNumberInput.value = e.target.value;
			updateCalculator();
		});

		homeEquityToggle.addEventListener('change', updateCalculator);

		updateCalculator();
	});
</script>
