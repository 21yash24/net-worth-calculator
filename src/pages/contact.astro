---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us | Net Worth Calculator by Age" description="Get in touch with the NetWorthCalc team for feedback or data inquiries.">
	<main class="max-w-2xl mx-auto px-4 py-12 md:py-20">
		<header class="text-center mb-12">
			<h1 class="text-4xl font-bold text-white mb-4">Contact Us</h1>
			<p class="text-slate-400">Have feedback or data suggestions? We'd love to hear from you.</p>
		</header>

		<div class="glass-panel p-8 rounded-3xl border border-white/10 bg-slate-900/60 backdrop-blur-xl">
			<form class="space-y-6" onsubmit="event.preventDefault(); alert('Thank you! Your message has been received.');">
				<div>
					<label class="block text-sm font-medium text-slate-300 mb-2">Your Name</label>
					<input type="text" required class="w-full bg-slate-950/80 border border-slate-700 text-white rounded-xl px-4 py-3 outline-none focus:border-sky-500" placeholder="John Doe">
				</div>

				<div>
					<label class="block text-sm font-medium text-slate-300 mb-2">Email Address</label>
					<input type="email" required class="w-full bg-slate-950/80 border border-slate-700 text-white rounded-xl px-4 py-3 outline-none focus:border-sky-500" placeholder="john@example.com">
				</div>

				<div>
					<label class="block text-sm font-medium text-slate-300 mb-2">Message</label>
					<textarea rows="4" required class="w-full bg-slate-950/80 border border-slate-700 text-white rounded-xl px-4 py-3 outline-none focus:border-sky-500" placeholder="How can we help?"></textarea>
				</div>

				<button type="submit" class="w-full py-4 rounded-xl bg-gradient-to-r from-sky-500 to-emerald-500 text-white font-bold text-lg hover:from-sky-400 hover:to-emerald-400 transition-all">
					Send Message
				</button>
			</form>
		</div>
	</main>
</Layout>
