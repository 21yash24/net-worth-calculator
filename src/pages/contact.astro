---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us | Net Worth Calculator by Age" description="Get in touch with the NetWorth team for feedback or data inquiries.">
	<main class="max-w-2xl mx-auto px-6 py-12 md:py-20">
		<header class="text-center mb-12 space-y-2">
			<h1 class="text-4xl font-extrabold text-slate-900 dark:text-white tracking-tight">Contact Us</h1>
			<p class="text-slate-700 dark:text-slate-400">Have feedback or data suggestions? We'd love to hear from you.</p>
		</header>

		<div class="p-8 rounded-3xl border border-slate-200 dark:border-slate-800/80 bg-white/95 dark:bg-slate-900/60 shadow-xl backdrop-blur-xl">
			<form class="space-y-6" onsubmit="event.preventDefault(); alert('Thank you! Your message has been received.');">
				<div>
					<label for="contact-name" class="block text-sm font-bold text-slate-800 dark:text-slate-200 mb-2">Your Name</label>
					<input id="contact-name" type="text" required class="w-full bg-slate-100 dark:bg-slate-950 border border-slate-300 dark:border-slate-800 text-slate-900 dark:text-white rounded-xl px-4 py-3 outline-none focus:ring-1 focus:ring-emerald-500 font-medium" placeholder="John Doe">
				</div>

				<div>
					<label for="contact-email" class="block text-sm font-bold text-slate-800 dark:text-slate-200 mb-2">Email Address</label>
					<input id="contact-email" type="email" required class="w-full bg-slate-100 dark:bg-slate-950 border border-slate-300 dark:border-slate-800 text-slate-900 dark:text-white rounded-xl px-4 py-3 outline-none focus:ring-1 focus:ring-emerald-500 font-medium" placeholder="john@example.com">
				</div>

				<div>
					<label for="contact-message" class="block text-sm font-bold text-slate-800 dark:text-slate-200 mb-2">Message</label>
					<textarea id="contact-message" rows="4" required class="w-full bg-slate-100 dark:bg-slate-950 border border-slate-300 dark:border-slate-800 text-slate-900 dark:text-white rounded-xl px-4 py-3 outline-none focus:ring-1 focus:ring-emerald-500 font-medium" placeholder="How can we help?"></textarea>
				</div>

				<button type="submit" class="w-full py-4 rounded-xl bg-emerald-700 hover:bg-emerald-600 text-white font-bold text-base transition-all shadow-md">
					Send Message
				</button>
			</form>
		</div>
	</main>
</Layout>
