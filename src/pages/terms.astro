---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Terms of Service & Disclaimer | Net Worth Calculator by Age">
	<main class="max-w-4xl mx-auto px-4 py-12 md:py-20">
		<header class="text-center mb-12">
			<h1 class="text-4xl font-bold text-white mb-4">Terms of Service & Financial Disclaimer</h1>
			<p class="text-slate-400">Effective Date: {new Date().getFullYear()}</p>
		</header>

		<div class="glass-panel p-8 md:p-12 rounded-3xl border border-white/10 bg-slate-900/60 backdrop-blur-xl text-slate-300 space-y-6">
			<section>
				<h2 class="text-xl font-bold text-white mb-2">1. Educational & Benchmark Purpose Only</h2>
				<p>NetWorthCalc is provided for informational and benchmark comparison purposes only. Calculations are based on statistical sampling from the US Federal Reserve Survey of Consumer Finances (SCF). This tool does not constitute individualized financial, investment, tax, or legal advice.</p>
			</section>

			<section>
				<h2 class="text-xl font-bold text-white mb-2">2. No Financial Advisor Relationship</h2>
				<p>Use of this site does not create a fiduciary or financial advisor relationship. Always consult a certified financial planner (CFP) or tax professional for your personal financial planning.</p>
			</section>
		</div>
	</main>
</Layout>
